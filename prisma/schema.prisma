// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Role hierarchy: USER < SUPERUSER < ADMINISTRATOR
enum Role {
  ADMINISTRATOR
  SUPERUSER
  USER
}


model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  username      String?   @unique 

  // Auth source: exactly ONE must be populated (enforced in app logic)
  // For local auth: use passwordHash
  // For LDAP: use ldapUsername (and set passwordHash to null)
  passwordHash  String?   // Local auth: bcrypt hash
  ldapUsername  String?   @unique   // LDAP: sAMAccountName or uid

  role          Role      @default(USER)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?

  // Password reset tokens (local accounts only)
  passwordResetTokens PasswordResetToken[]

  // Fine-grained RBAC permissions on top of the role hierarchy
  permissions   UserPermission[]

   // User's files (owned by the user) 
  files               File[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  // Map your Prisma model name to a different table name in your underlying database.
  @@index([isActive]) // filter active users
  @@index([role]) // filter by role
  @@index([createdAt]) // sorting/pagination
  @@map("users")
}

// Used by POST /auth/forgot-password and POST /auth/reset-password
model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique  // hashed with SHA-256 before storage
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  usedAt    DateTime? // When token was consumed (null = not used yet)
  createdAt DateTime  @default(now())

 @@index([expiresAt]) // cleanup expired tokens
  @@index([userId, expiresAt]) // find user's valid tokens
  @@map("password_reset_tokens")
}

// The permission catalogue — seeded once, never changes at runtime
model Permission {
  id          String           @id @default(cuid())
  key         String           @unique  // e.g. "team:read", "billing:write"
  description String
  category    String           // e.g. "files", "users", "billing" (for grouping UI)

  users       UserPermission[]
  @@index([category])
  @@map("permissions")
}


// Which users have which permissions (many-to-many with audit fields)
model UserPermission {
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  // Who granted this permission (null = system-granted), cuid of the admin who granted this; null = system-granted

  grantedBy    String?
  grantedByUser User?     @relation("GrantedByUser", fields: [grantedBy], references: [id], onDelete: SetNull)
  grantedAt    DateTime   @default(now())
 
  @@id([userId, permissionId])
  @@index([permissionId]) // find users with a specific permission
  @@index([grantedById]) // audit: who granted permissions
  @@map("user_permissions")
}

// Uploaded files with audit trail
model File {
  id            String    @id @default(cuid())
  
  // Original uploaded file metadata
  filename      String
  mimeType      String    // "application/pdf", "application/vnd.ms-word", etc.
  size          BigInt    // bytes
  
  // Storage
  storagePath   String    // where original file is stored
  storageType   String    @default("local") // "local", "s3", "gcs"
  
  // Ownership
  uploadedBy    String
  user          User      @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  
  // Relations
  content       FileContent?  // latest parsed content (optional)
  
  // Soft delete
  deletedAt     DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([uploadedBy])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("files")
}

// Parsing/conversion: separate concern
model FileContent {
  id            String    @id @default(cuid())
  fileId        String    @unique  // one active parse per file
  file          File      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  
  // Parse status & tracking
  parseStatus   String    @default("pending") // "pending", "parsed", "failed"
  parsedAt      DateTime?
  parseError    String?   // error message if failed
  parseVersion  Int       @default(1) // track if file is reparsed
  
  // Parsed output
  markdownPath  String?   // where markdown lives (S3/filesystem)
  metadata      String?   // JSON: {title, summary, wordCount, chunks, etc.}
  
  // Soft delete
  deletedAt     DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([fileId])
  @@index([parseStatus])
  @@index([createdAt])
  @@map("file_contents")
}