// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Role hierarchy: USER < SUPERUSER < ADMINISTRATOR
enum Role {
  ADMINISTRATOR
  SUPERUSER
  USER
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String
  username String? @unique

  // Auth source: exactly ONE must be populated (enforced in app logic)
  // For local auth: use passwordHash
  // For LDAP: use ldapUsername (and set passwordHash to null)
  passwordHash String? // Local auth: bcrypt hash
  ldapUsername String? @unique // LDAP: sAMAccountName or uid

  role        Role      @default(USER)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?

  // Password reset tokens (local accounts only)
  passwordResetTokens PasswordResetToken[]

  // Fine-grained RBAC permissions on top of the role hierarchy
  permissions UserPermission[]

  // User's files (owned by the user) 
  files File[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userPermissions UserPermission[] @relation("GrantedByUser")

  // Map your Prisma model name to a different table name in your underlying database.
  @@index([isActive]) // filter active users
  @@index([role]) // filter by role
  @@index([createdAt]) // sorting/pagination
  @@map("users")
}

// Used by POST /auth/forgot-password and POST /auth/reset-password
model PasswordResetToken {
  id     String @id @default(cuid())
  token  String @unique // hashed with SHA-256 before storage
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  usedAt    DateTime? // When token was consumed (null = not used yet)
  createdAt DateTime  @default(now())

  @@index([expiresAt]) // cleanup expired tokens
  @@index([userId, expiresAt]) // find user's valid tokens
  @@map("password_reset_tokens")
}

// The permission catalogue — seeded once, never changes at runtime
model Permission {
  id          String @id @default(cuid())
  key         String @unique // e.g. "team:read", "billing:write"
  description String
  category    String // e.g. "files", "users", "billing" (for grouping UI)

  users UserPermission[]

  @@index([category])
  @@map("permissions")
}

// Which users have which permissions (many-to-many with audit fields)
model UserPermission {
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  // Who granted this permission (null = system-granted), cuid of the admin who granted this; null = system-granted

  grantedBy     String?
  grantedByUser User?    @relation("GrantedByUser", fields: [grantedBy], references: [id], onDelete: SetNull)
  grantedAt     DateTime @default(now())

  @@id([userId, permissionId])
  @@index([permissionId]) // find users with a specific permission
  @@index([grantedBy]) // audit: who granted permissions
  @@map("user_permissions")
}

// Uploaded files with audit trail
model File {
  id String @id @default(cuid())

  // Original uploaded file metadata
  filename String
  mimeType String // "application/pdf", "application/vnd.ms-word", etc.
  size     BigInt // bytes

  // Storage
  storagePath String // where original file is stored
  storageType String @default("local") // "local", "s3", "gcs"

  // Ownership
  uploadedBy String
  user       User   @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)

  // Relations
  content FileContent? // latest parsed content (optional)

  // Soft delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([uploadedBy]) // for "my files" pagination
  @@index([deletedAt]) // filter soft-deletes
  @@index([createdAt]) // for "newest first" sorting
  @@map("files")
}

// Document classification & metadata extraction
model DocumentAnalysis {
  id            String      @id @default(cuid())
  fileContentId String      @unique
  fileContent   FileContent @relation(fields: [fileContentId], references: [id], onDelete: Cascade)

  // LLM classification
  documentType           String // "protocol", "scientific_paper", "white_paper", etc.
  documentTypeConfidence Float // 0-1 confidence score

  // Extracted metadata suggested by LLM
  extractedMetadata String // JSON: {title, authors, summary, keywords, abstract, etc.}

  // Status in workflow
  status String @default("pending") // "pending", "extracted", "user_reviewed", "approved"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fileContentId])
  @@index([status])
  @@map("document_analyses")
}

// Chunking strategy proposals & user feedback
model ChunkingProposal {
  id            String      @id @default(cuid())
  fileContentId String      @unique
  fileContent   FileContent @relation(fields: [fileContentId], references: [id], onDelete: Cascade)

  // LLM suggestions (multiple methods proposed)
  suggestedMethods String // JSON array: [{method: "semantic", params: {...}}, {method: "sliding_window", params: {...}}]

  // User selects & refines
  selectedMethod String? // which method user chose
  userFeedback   String? // JSON: what user changed/refined

  // Final approved strategy
  finalStrategy String? // JSON: {method, chunkSize, overlap, etc.}

  // Status in workflow
  status String @default("pending") // "pending", "suggested", "user_reviewed", "finalized"

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  chunkPreviews ChunkPreview[]

  @@index([fileContentId])
  @@index([status])
  @@map("chunking_proposals")
}

// Preview: chunks before finalization
model ChunkPreview {
  id         String           @id @default(cuid())
  proposalId String
  proposal   ChunkingProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  chunkIndex Int // chunk 0, 1, 2, etc.
  content    String // preview of chunk (first 500 chars or full)
  startChar  Int // where in markdown
  endChar    Int

  // User feedback on this chunk
  userFeedback String? // e.g. "split this, too long"

  createdAt DateTime @default(now())

  @@index([proposalId])
  @@map("chunk_previews")
}

// Track which chunks have been embedded in ChromaDB
model ChunkEmbedding {
  id      String @id @default(cuid())
  chunkId String @unique
  chunk   Chunk  @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  // ChromaDB reference
  chromaId         String @unique // Document ID in ChromaDB collection
  chromaCollection String // which collection: "default", "file_123", etc.

  // Embedding model metadata
  embeddingModel String // "openai/text-embedding-3-small", "sentence-transformers/...", etc.
  embeddingDim   Int // vector dimensions (1536 for OpenAI, 384 for sentence-transformers, etc.)

  status     String    @default("pending") // "pending", "embedded", "failed"
  embeddedAt DateTime?
  error      String?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  fileContent   FileContent? @relation(fields: [fileContentId], references: [id])
  fileContentId String?

  @@index([chunkId])
  @@index([chromaCollection])
  @@index([status])
  @@map("chunk_embeddings")
}

// Optional: Track RAG retrievals for monitoring/analytics
model RagRetrieval {
  id            String      @id @default(cuid())
  fileContentId String
  fileContent   FileContent @relation(fields: [fileContentId], references: [id], onDelete: Cascade)

  // Query that triggered retrieval
  query String // user question or search query

  // Retrieved chunks (JSON: array of chunkId + similarity scores)
  retrievedChunks String // JSON: [{chunkId, similarity: 0.87}, ...]

  // LLM response
  llmResponse String? // summarized answer or relevant context

  createdAt DateTime @default(now())

  @@index([fileContentId])
  @@index([createdAt])
  @@map("rag_retrievals")
}

// LangChain chain execution history (optional but useful for debugging)
model ChainExecution {
  id            String      @id @default(cuid())
  fileContentId String
  fileContent   FileContent @relation(fields: [fileContentId], references: [id], onDelete: Cascade)

  // Which chain was executed
  chainType String // "classification", "metadata_extraction", "chunking_strategy", etc.

  // Input & output
  input  String // JSON: input to the chain
  output String // JSON: output from chain

  // LLM details
  model         String // "gpt-4", "claude-3-sonnet", etc.
  tokensUsed    Int?
  executionTime Int? // milliseconds

  status String // "success", "failed"
  error  String?

  createdAt DateTime @default(now())

  @@index([fileContentId])
  @@index([chainType])
  @@map("chain_executions")
}

// Parsing/conversion: separate concern
model FileContent {
  id     String @id @default(cuid())
  fileId String @unique // one active parse per file
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  parseStatus  String    @default("pending") // "pending", "parsed", "failed"
  parsedAt     DateTime?
  parseError   String? // error message if failed
  parseVersion Int       @default(1) // track if file is reparsed

  markdownPath String? // where markdown lives (S3/filesystem)
  metadata     String? // JSON: {title, summary, wordCount, chunks, etc.}

  // Workflow
  analysis DocumentAnalysis?
  proposal ChunkingProposal?
  chunks   Chunk[]

  // NEW: LangChain & ChromaDB integrations
  embeddings      ChunkEmbedding[]
  retrievals      RagRetrieval[]
  chainExecutions ChainExecution[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([createdAt])
  @@map("file_contents")
}

// Final chunks after user approval
model Chunk {
  id            String      @id @default(cuid())
  fileContentId String
  fileContent   FileContent @relation(fields: [fileContentId], references: [id], onDelete: Cascade)

  chunkIndex Int
  content    String // actual chunk text
  startChar  Int
  endChar    Int

  // Metadata for RAG
  heading String? // section heading if extracted

  // NEW: ChromaDB embedding reference
  // For vector embeddings 
  embeddingId String? // reference to embedding store (Pinecone, Weaviate, etc.)

  createdAt      DateTime        @default(now())
  chunkEmbedding ChunkEmbedding?

  @@unique([fileContentId, chunkIndex])
  @@index([fileContentId]) // pagination within a file's chunks
  @@map("chunks")
}
